{
  "name": "search-for-fun",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Local-first game-design search with Codex and KAPLAY.",
  "scripts": {
    "dev": "node --import tsx studio/server/index.ts",
    "studio:ensure": "node --import tsx .agents/skills/search-for-fun/scripts/manage-studio.ts ensure",
    "studio:restart": "node --import tsx .agents/skills/search-for-fun/scripts/manage-studio.ts restart",
    "studio:status": "node --import tsx .agents/skills/search-for-fun/scripts/manage-studio.ts status",
    "studio:stop": "node --import tsx .agents/skills/search-for-fun/scripts/manage-studio.ts stop",
    "build": "npm run typecheck && npm run build:client && npm run build:server",
    "build:client": "vite build",
    "build:server": "esbuild studio/server/index.ts --bundle --platform=node --format=esm --packages=external --outfile=dist/server/index.js",
    "start": "node dist/server/index.js --production",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "validate": "node --import tsx .agents/skills/search-for-fun/scripts/validate-search.ts --all",
    "search:create": "node --import tsx .agents/skills/search-for-fun/scripts/create-search.ts",
    "search:import": "node --import tsx .agents/skills/search-for-fun/scripts/import-node.ts",
    "search:claim": "node --import tsx .agents/skills/search-for-fun/scripts/claim-command.ts",
    "search:complete": "node --import tsx .agents/skills/search-for-fun/scripts/complete-command.ts",
    "search:fail": "node --import tsx .agents/skills/search-for-fun/scripts/fail-command.ts",
    "search:summarize": "node --import tsx .agents/skills/search-for-fun/scripts/summarize-search.ts",
    "check": "npm run test && npm run validate && npm run build"
  },
  "engines": {
    "node": ">=20.19"
  },
  "dependencies": {
    "ajv": "8.20.0",
    "ajv-formats": "3.0.1",
    "express": "5.2.1",
    "kaplay": "4000.0.0-alpha.27.1",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@types/express": "5.0.6",
    "@types/node": "26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@types/supertest": "7.2.1",
    "@vitejs/plugin-react": "6.0.3",
    "esbuild": "0.28.1",
    "supertest": "7.2.2",
    "tsx": "4.23.1",
    "typescript": "7.0.2",
    "vite": "8.1.5",
    "vitest": "4.1.10"
  }
}
