{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "allowJs": false,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "paths": {
      "@search-for-fun/runtime": ["./studio/runtime/contract.ts"],
      "@studio/*": ["./studio/*"]
    },
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "types": ["node", "vitest/globals"]
  },
  "include": [
    "studio/**/*.ts",
    "studio/**/*.tsx",
    "tests/**/*.ts",
    ".agents/skills/search-for-fun/scripts/**/*.ts",
    "searches/**/*.ts",
    "vite.config.ts",
    "vitest.config.ts"
  ]
}
