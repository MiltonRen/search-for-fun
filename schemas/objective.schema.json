{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://search-for-fun.local/schemas/objective.schema.json",
  "title": "Objective revision",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "searchId", "revision", "createdAt", "successMode", "fantasy", "desiredFeeling", "sessionLengthSeconds", "constraints", "rubric"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "searchId": { "type": "string", "pattern": "^s_[0-9]{8}_[a-z0-9_]+$" },
    "revision": { "type": "integer", "minimum": 1 },
    "createdAt": { "type": "string", "format": "date-time" },
    "successMode": { "enum": ["joy", "portfolio", "commercial", "learning", "custom"] },
    "fantasy": { "type": "string", "minLength": 1, "maxLength": 500 },
    "desiredFeeling": {
      "type": "array",
      "minItems": 1,
      "maxItems": 8,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1, "maxLength": 60 }
    },
    "sessionLengthSeconds": {
      "type": "array",
      "prefixItems": [
        { "type": "integer", "minimum": 5, "maximum": 3600 },
        { "type": "integer", "minimum": 5, "maximum": 7200 }
      ],
      "minItems": 2,
      "maxItems": 2
    },
    "constraints": {
      "type": "array",
      "maxItems": 20,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1, "maxLength": 240 }
    },
    "rubric": {
      "type": "array",
      "minItems": 1,
      "maxItems": 12,
      "uniqueItems": true,
      "items": { "type": "string", "pattern": "^[a-z][A-Za-z0-9]*$" }
    },
    "referenceGames": {
      "type": "array",
      "maxItems": 12,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1, "maxLength": 120 }
    },
    "avoidPatterns": {
      "type": "array",
      "maxItems": 12,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1, "maxLength": 180 }
    },
    "innovationTarget": { "enum": ["familiar", "balanced", "experimental"] }
  }
}
